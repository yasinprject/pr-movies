<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#050814">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginBottom="56dp">
        <WebView
            android:id="@+id/myWebView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:overScrollMode="never"
            android:visibility="gone" />
    </FrameLayout>

    <ProgressBar
        android:id="@+id/topProgress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:max="100"
        android:progressTint="#E50914" 
        android:layout_gravity="top"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/bottomNavLayout"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_gravity="bottom"
        android:orientation="horizontal"
        android:background="#101422"
        android:elevation="8dp">

        <LinearLayout android:id="@+id/tab1" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:orientation="vertical" android:background="?android:attr/selectableItemBackground">
            <ImageView android:id="@+id/iconTab1" android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_prmovies" android:tint="#E50914" />
            <TextView android:id="@+id/textTab1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="PRMovies" android:textColor="#E50914" android:textSize="11sp" android:layout_marginTop="2dp" android:textStyle="bold"/>
        </LinearLayout>
        <LinearLayout android:id="@+id/tab2" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:orientation="vertical" android:background="?android:attr/selectableItemBackground">
            <ImageView android:id="@+id/iconTab2" android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_watchomovies" android:tint="#888888" />
            <TextView android:id="@+id/textTab2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="WatchO" android:textColor="#888888" android:textSize="11sp" android:layout_marginTop="2dp" android:textStyle="bold"/>
        </LinearLayout>
        <LinearLayout android:id="@+id/tab3" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:orientation="vertical" android:background="?android:attr/selectableItemBackground">
            <ImageView android:id="@+id/iconTab3" android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_xhamster" android:tint="#888888" />
            <TextView android:id="@+id/textTab3" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="xHamster" android:textColor="#888888" android:textSize="11sp" android:layout_marginTop="2dp" android:textStyle="bold"/>
        </LinearLayout>
        <LinearLayout android:id="@+id/tab4" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:orientation="vertical" android:background="?android:attr/selectableItemBackground">
            <ImageView android:id="@+id/iconTab4" android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_xnxx" android:tint="#888888" />
            <TextView android:id="@+id/textTab4" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="XNXX" android:textColor="#888888" android:textSize="11sp" android:layout_marginTop="2dp" android:textStyle="bold"/>
        </LinearLayout>
    </LinearLayout>

    <FrameLayout
        android:id="@+id/fullscreenContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#000000"
        android:elevation="10dp"
        android:visibility="gone">
        <LinearLayout
            android:id="@+id/swipeIndicatorLayout"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:layout_gravity="center"
            android:background="@drawable/bg_indicator"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone">
            <ImageView
                android:id="@+id/swipeIndicatorIcon"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:tint="#FFFFFF" />
            <TextView
                android:id="@+id/swipeIndicatorText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>
    </FrameLayout>

    <LinearLayout
        android:id="@+id/lockScreenLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:background="#050814"
        android:elevation="15dp"
        android:visibility="gone">
        <ImageView android:layout_width="80dp" android:layout_height="80dp" android:src="@drawable/ic_launcher" android:layout_marginBottom="20dp" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Enter Password" android:textColor="#FFFFFF" android:textSize="18sp" android:textStyle="bold" android:layout_marginBottom="16dp" />
        <EditText android:id="@+id/etPassword" android:layout_width="200dp" android:layout_height="wrap_content" android:hint="****" android:textColorHint="#888888" android:textColor="#FFFFFF" android:inputType="numberPassword" android:gravity="center" android:background="@android:drawable/edit_text" android:layout_marginBottom="24dp" />
        <Button android:id="@+id/btnUnlock" android:layout_width="wrap_content" android:layout_height="wrap_content" android:backgroundTint="#E50914" android:text="Unlock App" android:textColor="#FFFFFF" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/splashLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:background="#050814"
        android:elevation="20dp">
        <ImageView android:layout_width="120dp" android:layout_height="120dp" android:src="@drawable/ic_launcher" />
    </LinearLayout>
</FrameLayout>
